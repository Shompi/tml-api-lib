{
  "name": "tml-api-lib",
  "author": "ShompiFlen",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "bunx rimraf dist",
    "build:cjs": "bunx tsc -p tsconfig.cjs.json && echo '{\"type\": \"commonjs\"}' > dist/cjs/package.json",
    "build:esm": "bunx tsc -p tsconfig.esm.json",
    "build": "bun run clean && bun run build:cjs && bun run build:esm",
    "prepublishOnly": "bunx run build"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}